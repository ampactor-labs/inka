import compiler/parser
import compiler/codegen

fn try_compile(name, path) = {
  let source = read_file(path)
  println(name ++ ": " ++ to_string(len(source)) ++ " chars")
  let chunk = compile(source)
  let (code, constants, names) = chunk
  println("  → " ++ to_string(len(code)) ++ " bytes, " ++
          to_string(len(constants)) ++ " constants, " ++
          to_string(len(names)) ++ " names")
}

println("=== Bootstrap: Self-Hosted Compiler Compiles Itself ===")
println("")
try_compile("lexer.lux  ", "std/compiler/lexer.lux")
try_compile("parser.lux ", "std/compiler/parser.lux")
try_compile("checker.lux", "std/compiler/checker.lux")
try_compile("codegen.lux", "std/compiler/codegen.lux")
println("")
println("=== All four modules compiled ===")
