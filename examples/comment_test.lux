import compiler/lexer

let tokens = lex("let x = 42 // comment\nlet y = 7")
println("tokens: " ++ to_string(len(tokens)))
let i = 0
fn show_tokens(tokens, i) = {
  if i < len(tokens) {
    let (typ, val, _, _) = tokens[i]
    println(to_string(i) ++ ": " ++ typ ++ " " ++ val)
    show_tokens(tokens, i + 1)
  } else { () }
}
show_tokens(tokens, 0)
