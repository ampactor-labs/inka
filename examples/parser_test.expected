=== ADT Parser Test ===
let x = 42        => [LetStmt("x", S(IntLit("42"), 1, 9))]
1 + 2 * 3          => [ExprStmt(S(BinOp("Add", S(IntLit("1"), 1, 1), S(BinOp("Mul", S(IntLit("2"), 1, 5), S(IntLit("3"), 1, 9)), 1, 7)), 1, 3))]
f(1, 2)            => [ExprStmt(S(Call(S(VarRef("f"), 1, 1), [S(IntLit("1"), 1, 3), S(IntLit("2"), 1, 6)]), 1, 2))]
if x 1 else.. => [ExprStmt(S(IfExpr(S(VarRef("x"), 1, 4), S(IntLit("1"), 1, 6), S(IntLit("2"), 1, 13)), 1, 4))]
fn add(a, b)..     => [FnStmt("add", [("a", "inferred"), ("b", "inferred")], S(BinOp("Add", S(VarRef("a"), 1, 16), S(VarRef("b"), 1, 20)), 1, 18), [])]
f(g(1))            => [ExprStmt(S(Call(S(VarRef("f"), 1, 1), [S(Call(S(VarRef("g"), 1, 3), [S(IntLit("1"), 1, 5)]), 1, 4)]), 1, 2))]
[1, 2, 3]          => [ExprStmt(S(ListExpr([S(IntLit("1"), 1, 2), S(IntLit("2"), 1, 5), S(IntLit("3"), 1, 8)]), 1, 2))]
true               => [ExprStmt(S(BoolLit(true), 1, 1))]
-x                 => [ExprStmt(S(UnaryOp("Neg", S(VarRef("x"), 1, 2)), 1, 1))]
()                 => [ExprStmt(S(TupleExpr([]), 1, 2))]

Lux parsing itself. ADTs typing their own AST. One type system.
