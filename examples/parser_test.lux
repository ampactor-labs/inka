import compiler/parser

println("=== ADT Parser Test ===")

// Let binding
let r1 = parse("let x = 42")
println("let x = 42        => " ++ to_string(r1))

// Arithmetic
let r2 = parse("1 + 2 * 3")
println("1 + 2 * 3          => " ++ to_string(r2))

// Function call
let r3 = parse("f(1, 2)")
println("f(1, 2)            => " ++ to_string(r3))

// If expression
let r4 = parse("if x { 1 } else { 2 }")
println("if x { 1 } else.. => " ++ to_string(r4))

// Function declaration
let r5 = parse("fn add(a, b) = a + b")
println("fn add(a, b)..     => " ++ to_string(r5))

// Nested calls
let r6 = parse("f(g(1))")
println("f(g(1))            => " ++ to_string(r6))

// List literal
let r7 = parse("[1, 2, 3]")
println("[1, 2, 3]          => " ++ to_string(r7))

// Boolean
let r8 = parse("true")
println("true               => " ++ to_string(r8))

// Unary
let r9 = parse("-x")
println("-x                 => " ++ to_string(r9))

// Empty parens
let r10 = parse("()")
println("()                 => " ++ to_string(r10))

println("")
println("Lux parsing itself. ADTs typing their own AST. One type system.")
