// Test for strategy pipe ~>
// Desugars to HandleExpr(left, right, [])

effect Log { log(msg: String) -> () }

fn mock_logger(msg: String) -> () = println("[mock] {msg}")

fn app() with Log = {
  log("Starting up")
  log("Doing work")
  log("Shutting down")
}

fn main() = {
  println("=== Strategy Pipe ===")
  app() ~> {
    log: |msg| {
      mock_logger(msg)
      resume(())
    }
  }
}

main()
