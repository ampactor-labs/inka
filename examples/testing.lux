// Handle-as-Mock Pattern — Testing without a test framework
//
// Algebraic effects let you inject fake I/O at the call site.
// The function under test never touches real I/O — the handler
// decides what "console" means.

// ── Define the Console effect ────────────────────────────────────

effect Console {
  say(msg: String) -> ()
  ask(prompt: String) -> String
}

// ── Function under test ──────────────────────────────────────────
// greet_user uses Console but has no idea how it's implemented.

fn greet_user(name: String) -> String with Console {
  say("Hello, " ++ name ++ "!")
  say("How are you today?")
  let response = ask("Your response: ")
  "You said: " ++ response
}

// ── Test 1: Real handler (prints to stdout) ──────────────────────

println("=== Real console handler ===")
let result1 = handle greet_user("Alice") {
  say(msg) => {
    println("[console] " ++ msg)
    resume(())
  },
  ask(prompt) => {
    println("[console] " ++ prompt)
    resume("I'm doing great!")
  }
}
println("Return value: " ++ result1)

// ── Test 2: Silent mock (captures nothing, no output) ────────────
// Use case: ensure a function doesn't crash, ignore I/O side effects

println("")
println("=== Silent mock (no output) ===")
let result2 = handle greet_user("Bob") {
  say(msg) => resume(()),
  ask(prompt) => resume("canned answer")
}
println("Return value: " ++ result2)
println("(no [console] lines above - say() was silenced)")

// ── Test 3: Capturing mock ───────────────────────────────────────
// Use case: assert that the function called say() with specific messages

println("")
println("=== Capturing mock (recorded outputs) ===")

// We can't easily accumulate across resumes without stateful effects,
// but we CAN verify each call inline with the handler.

fn test_greet_outputs() -> () {
  let result = handle greet_user("Carol") {
    say(msg) => {
      // Each handler call verifies its own message inline
      if msg == "Hello, Carol!" {
        println("[PASS] say: " ++ msg)
      } else {
        if msg == "How are you today?" {
          println("[PASS] say: " ++ msg)
        } else {
          println("[FAIL] unexpected say: " ++ msg)
        }
      }
      resume(())
    },
    ask(prompt) => {
      if prompt == "Your response: " {
        println("[PASS] ask prompt matched")
      } else {
        println("[FAIL] unexpected ask: " ++ prompt)
      }
      resume("test input")
    }
  }
  println("Return value: " ++ result)
}

test_greet_outputs()

// ── Test 4: Error injection ──────────────────────────────────────
// Use case: test how the function behaves when I/O fails

effect Fail {
  fail(msg: String) -> Never
}

fn safe_greet(name: String) -> String with Console, Fail {
  if name == "" {
    fail("empty name")
  } else {
    say("Greeting " ++ name)
    "Hello, " ++ name ++ "!"
  }
}

println("")
println("=== Error injection mock ===")
let ok = handle {
  handle safe_greet("Dave") {
    say(msg) => { println("[mock] " ++ msg); resume(()) },
    ask(prompt) => resume("")
  }
} {
  fail(msg) => resume("ERROR: " ++ msg)
}
println("Result: " ++ ok)

let err = handle {
  handle safe_greet("") {
    say(msg) => { println("[mock] " ++ msg); resume(()) },
    ask(prompt) => resume("")
  }
} {
  fail(msg) => resume("ERROR: " ++ msg)
}
println("Result: " ++ err)

println("")
println("Key insight: greet_user never calls println directly.")
println("The handler is the test harness. No test framework needed.")
