// Crucible 3: Handler state as WASM locals
// Proves: effect handlers with state compile to zero-overhead WASM.
// No handler stack, no continuations — just local variables.

effect Counter {
  bump() -> ()
  count() -> Int
}

let val = handle {
  bump()
  bump()
  bump()
  count()
} with n = 0 {
  bump() => resume(()) with n = n + 1,
  count() => resume(n),
}
println("count = " ++ to_string(val))
