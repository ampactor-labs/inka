// Crucible 4: ADTs + pattern matching in WASM
// Proves: algebraic data types live in linear memory, pattern matching
// dispatches on tags, field extraction works.

type Shape = Circle(Int) | Rectangle(Int, Int)

fn area(s) = match s {
  Circle(r) => r * r * 3,
  Rectangle(w, h) => w * h,
}

println("circle: " ++ to_string(area(Circle(5))))
println("rect: " ++ to_string(area(Rectangle(4, 6))))
