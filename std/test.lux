// Lux test framework
// Usage: import test
//
// fn test_addition() = assert_eq(1 + 1, 2)
// fn test_greeting() = assert_eq("hello" ++ " world", "hello world")
//
// run_tests([
//   ("addition", test_addition),
//   ("greeting", test_greeting),
// ])

fn assert_eq(actual, expected) =
  if actual == expected { () }
  else { assert false, "expected " ++ to_string(expected) ++ " but got " ++ to_string(actual) }

fn assert_ne(actual, expected) =
  if actual != expected { () }
  else { assert false, "expected value different from " ++ to_string(expected) ++ " but got same" }

fn assert_true(value) =
  assert value, "expected true but got false"

fn assert_false(value) =
  assert !value, "expected false but got true"

fn run_tests(tests) = {
  let total = len(tests);
  let passed = fold(tests, 0, |count, test| {
    let (name, test_fn) = test;
    print("  test " ++ name ++ " ... ");
    // Run the test — if assert fails, it will halt (for now)
    test_fn();
    println("ok");
    count + 1
  });
  println("");
  println("test result: " ++ to_string(passed) ++ "/" ++ to_string(total) ++ " passed");
  passed
}
